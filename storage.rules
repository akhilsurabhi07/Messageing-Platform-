rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to upload/read meeting files
    match /meetings/{meetingId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    // Allow authenticated users to upload/read chat files (images, videos, documents)
    match /chats/{chatId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    // Allow authenticated users to upload profile pictures
    match /profiles/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
